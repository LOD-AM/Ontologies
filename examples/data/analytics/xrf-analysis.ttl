# AFO entities
:xrf_technique a afo:Technique ;
    afo:hasName "X-ray Fluorescence Spectroscopy" .

:xrf_spectrometer_01 a afo:Instrument ;
    afo:hasName "Bruker S2 PUMA" ;
    afo:hasModel "S2 PUMA" ;
    afo:hasManufacturer "Bruker" .

:xrf_method a afo:Method ;
    afo:hasName "Standard XRF Analysis Protocol for Archaeological Ceramics" .

# Methodology paper
:doi_xrf_methodology a crm:E42_Identifier ;
    crm:P2_has_type :doi_type ;
    crm:P190_has_symbolic_content "10.1234/xrf-methodology" .

:title_xrf_methodology a crm:E35_Title ;
    crm:P190_has_symbolic_content "XRF Analysis of Ancient Ceramics: A Comprehensive Methodology" .

:author_chemist a crm:E39_Actor ;
    crm:P131_is_identified_by :name_chemist .

:name_chemist a crm:E82_Actor_Appellation ;
    crm:P190_has_symbolic_content "Dr. Sarah Chemist" .

:publication_date_2020 a crm:E52_Time-Span ;
    crm:P82_at_some_time_within "2020"^^xsd:gYear .

