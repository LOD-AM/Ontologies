@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix afo: <http://www.allotrope.org/ontologies/result#> .
@prefix frbroo: <http://iflastandards.info/ns/fr/frbr/frbroo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# XRF Analysis of Pottery Shard 001

# The pottery shard
:pottery_shard_001 a crm:E22_Man-Made_Object ;
    crm:P1_is_identified_by :id_pottery_shard_001 ;
    crm:P2_has_type :pottery_type ;
    crm:P46_is_composed_of :clay_material .

# The sampling event
:sampling_001 a crm:E7_Activity ;
    crm:P1_is_identified_by :id_sampling_001 ;
    crm:P2_has_type :sampling_type ;
    crm:P16_used_specific_object :pottery_shard_001 ;
    crm:P14_carried_out_by :sampler_jane_doe ;
    crm:P4_has_time-span :sampling_date_2026 ;
    crm:P7_took_place_at :site_alpha ;
    crm:P128_carries :sample_001 ;
    crm:P3_has_note "1g sample taken from rim fragment for XRF analysis" .

# The sample
:sample_001 a crm:E73_Information_Object ;
    crm:P1_is_identified_by :id_sample_001 ;
    crm:P2_has_type :ceramic_sample_type ;
    crm:P3_has_note "Sample A from Pottery Shard 001, 1g, rim fragment" .

# The analysis event
:analysis_001 a crm:E7_Activity ;
    crm:P1_is_identified_by :id_analysis_001 ;
    crm:P2_has_type :xrf_analysis_type ;
    crm:P16_used_specific_object :sample_001 ;
    crm:P14_carried_out_by :analyst_john_doe ;
    crm:P4_has_time-span :analysis_date_2026 ;
    crm:P7_took_place_at :lab_001 ;
    crm:P128_carries :xrf_result_001 ;
    crm:P67_refers_to :xrf_methodology_paper ;
    crm:P3_has_note "XRF analysis of pottery shard for chemical composition" .

# The analysis result
:xrf_result_001 a afo:MeasurementResult ;
    afo:hasValue "18.5"^^xsd:decimal ;
    afo:hasUnit afo:Percent ;
    afo:hasTechnique :xrf_technique ;
    afo:hasInstrument :xrf_spectrometer_01 ;
    afo:hasSample :sample_001 ;
    afo:hasMethod :xrf_method .

# Methodology citation
:xrf_methodology_paper a frbroo:F1_Work ;
    crm:P1_is_identified_by :doi_xrf_methodology ;
    crm:P102_has_title :title_xrf_methodology ;
    crm:P94_has_created :author_chemist ;
    crm:P4_has_time-span :publication_date_2020 .

