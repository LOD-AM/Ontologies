# Excavation Report for Site Alpha

# The work (main bibliographic entity)
:excavation_report_1985 a frbroo:F1_Work ;
    # Identification
    crm:P1_is_identified_by :local_id_arch_1985_001, :isbn_0123456789 ;
    
    # Title
    crm:P102_has_title :title_excavation_report ;
    
    # Creator (author)
    crm:P94_has_created :author_dr_jane_archaeologist ;
    
    # Publication date
    crm:P4_has_time-span :publication_date_1987 ;
    
    # References to archaeological entities
    crm:P67_refers_to :site_alpha, :pottery_shard_001, :stone_tool_002 ;
    
    # Description
    crm:P3_has_note "Comprehensive excavation report for Site Alpha, covering the 1985 season. Includes detailed stratigraphy, artifact catalog, and preliminary analysis." .

